# ---- Provider selection ----
# openai | anthropic
AI_PROVIDER=anthropic

# ---- Anthropic ----
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.1

# ---- Web search (optional; required only if the web_search tool is used) ----
EXA_API_KEY=

# ---- RAG / embeddings (optional; required only for /index and the get_information tool) ----
# Embedding model: Voyage. Sign up at https://voyageai.com (200M free tokens for the voyage-3 family).
VOYAGE_API_KEY=
# VOYAGE_BASE_URL=https://api.voyageai.com/v1
# KOKKO_VOYAGE_MODEL=voyage-3-large
#
# Vector store: Pinecone. Sign up at https://app.pinecone.io (Starter plan is free, 2GB).
PINECONE_API_KEY=
# KOKKO_PINECONE_INDEX=kokko        # index name (auto-created on first /index)
# PINECONE_CLOUD=aws                # aws | gcp | azure (Starter only supports aws)
# PINECONE_REGION=us-east-1         # Starter only supports us-east-1

# ---- System prompt (optional) ----
# Path to a file whose contents replace the built-in base system prompt.
# If unset, kokko uses its built-in default.
# KOKKO_SYSTEM_PROMPT_FILE=
